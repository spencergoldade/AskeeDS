/* AskeeDS component visual test — section styling
   Maps to design tokens: color-bg-surface (default), color-bg-subtle (grouped content). */

/* Section headers: make titles and dividers stand out; add separation between sections */
.section_title {
  text-style: bold;
  margin-top: 1;
}

.section_subtitle {
  color: $foreground-muted;
  margin-bottom: 0;
}

.section_divider {
  color: $foreground-muted;
}

/* Filter bar: subtle background to separate from list */
.section_filter_bar {
  background: $surface-darken-1;
  padding: 0 1 1 1;
}

/* Component list area */
.section_list {
  background: $surface;
}

/* Detail screen: reference art block — distinct card with inner spacing (2 cells for clear separation) */
.section_reference {
  background: $surface-darken-1;
  padding: 2 2 2 2;
  margin-top: 2;
}

/* Props editing area */
.section_props {
  background: $surface;
  padding: 2 2 2 2;
  margin-top: 2;
}

/* Array prop: label above TextArea, with spacing between multiple array props */
.prop_array_row {
  margin-bottom: 1;
}

/* Preview block — consistent with reference; extra margin above to separate from props list */
.section_preview {
  background: $surface-darken-1;
  padding: 2 2 2 2;
  margin-top: 1;
}

/* Padding around component art on all sides so it is clearly separated from other UI */
.art_block {
  padding: 2;
}

/* color_role preview styling — values must match design/ascii/askee_ds_tokens.yaml */
.color-role-neutral {
  background: #1e1e1e;
  color: #d4d4d4;
  border: solid #404040;
}
.color-role-danger {
  background: #2d1b1b;
  color: #f48771;
  border: solid #8b3a3a;
}
.color-role-arcane {
  background: #251b2d;
  color: #d4a0f0;
  border: solid #6b4a7b;
}
.color-role-nature {
  background: #1b2d1b;
  color: #90c990;
  border: solid #4a6b4a;
}
.color-role-frost {
  background: #1b252d;
  color: #90c9d4;
  border: solid #4a6b7b;
}
.color-role-success {
  background: #2d2d1b;
  color: #c9c990;
  border: solid #6b6b4a;
}
.color-role-rare {
  background: #1b1b2d;
  color: #90a0d4;
  border: solid #4a5a8b;
}
.color-role-legendary {
  background: #2d251b;
  color: #d4c090;
  border: solid #8b7b4a;
}
.color-role-dungeon {
  background: #252525;
  color: #a0a0a0;
  border: solid #505050;
}
.color-role-forest {
  background: #1e251b;
  color: #a0b890;
  border: solid #5a6b4a;
}

/* Figlet font browser: list left, preview right */
.figlet_list_container {
  width: 22;
  min-width: 18;
}

.figlet_preview_container {
  width: 1fr;
  padding-left: 2;
  overflow: auto;
}

.section_muted {
  color: $foreground-muted;
}

/* Detail screen: component overview pane — scrollable, fixed height so rest of screen stays visible */
.overview_pane {
  height: 16;
  max-height: 16;
  border: solid $foreground-muted;
  padding: 1 1 1 1;
}

/* OptionList: highlight/hover must stay readable when option text is green (approved).
   Use neutral background and border so focus is visible without blue-over-green. */
OptionList .option-list--option-highlighted {
  background: $surface-darken-1;
  border-left: tall $foreground-muted;
}
OptionList .option-list--option-hover {
  background: $surface-darken-1;
  border-left: tall $foreground-muted;
}
