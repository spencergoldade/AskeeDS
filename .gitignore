# Ignore Cursor configuration and state
.cursor/
profiles/

# Design / research / content — local only. Do not un-ignore without
# sanitizing (no editor-specific paths, no secrets). Public-facing
# design docs belong in repo root or design/ files that are not ignored.
design/tokens/
design/research/
design/ia/
design/content/

# Local reassessment and plan docs (do not ship)
design/DESIGN-LENS-REASSESSMENT.md

# Release checklist (local for now)
RELEASE_CHECKLIST.md

# Local docs — do not un-ignore without sanitizing. Ship only
# user-facing guides; strip internal tooling and workflow references.
docs/

# Backlog / planning — keep ignored. Surface “What’s next” via
# ROADMAP or issues; do not expose raw tickets with internal IDs.
tickets/

# Virtual environments
.venv/
.venv*/

# Python bytecode and cache
__pycache__/
*.pyc
*.pyo

# Local merge backup (script creates components.txt.bak)
*.bak
